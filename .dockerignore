# Version control
.git
.gitignore

# Local env / secrets (provided via platform env vars in production)
.env
.env.*

# Runtime artifacts
downloads/

# Local Python venv (the image installs instaloader into /opt/yt)
.venv/

# Locally compiled binaries — the image builds its own inside the builder stage
downloader-bot
yt-dlp_bin
*.exe
*.exe~

# Cookie files — injected at runtime via *_COOKIES_B64 env, never baked in
instagram.txt
youtube.txt
twitter.txt
facebook.txt
pinterest.txt

# Docs / local logs not needed in the image
README.md
users.txt
